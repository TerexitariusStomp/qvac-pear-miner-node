# QVAC-Pear Miner Node Environment Configuration

# Node Configuration
NODE_ID=02b8357bdd44fbb6bd12f2b07cc993ee
NODE_NAME=QVAC-Pear Miner Node
NODE_VERSION=1.0.0

# API Configuration
API_PORT=3000
API_HOST=0.0.0.0

# Inference Configuration
INFERENCE_ENABLED=true
INFERENCE_MAX_CONCURRENT=4
INFERENCE_IDLE_TIMEOUT=300000

# Miner Configuration
MINERS_ENABLED=true
MINERS_PARALLEL_MODE=true
MINERS_SWITCH_INTERVAL=60000

# Individual Miner Configuration
CORTENSOR_ENABLED=true
CHUTES_ENABLED=true
FORTYTWO_ENABLED=true
EARNIDLE_ENABLED=true
ROUTSTR_ENABLED=true

# Wallet Configuration (Optional - add your wallet addresses)
CORTENSOR_WALLET_ADDRESS=
CHUTES_WALLET_ADDRESS=
FORTYTWO_WALLET_ADDRESS=
EARNIDLE_WALLET_ADDRESS=
ROUTSTR_WALLET_ADDRESS=

# P2P Configuration
P2P_ENABLED=true
PEAR_ENABLED=true
PEAR_DISCOVERY=true
HYPERCORE_STORAGE=./data/hypercore
HYPERCORE_REPLICATE=true

# Scheduler Configuration
SCHEDULER_ENABLED=true
SCHEDULER_NIGHT_START=20
SCHEDULER_NIGHT_END=6
SCHEDULER_TIMEZONE=UTC

# Storage Configuration
STORAGE_PATH=./data
STORAGE_ENCRYPTION=true

# Authentication Configuration
AUTH_METHOD=signin
AUTH_REQUIRED=true

# Environment
NODE_ENV=production

# Fleet Orchestrator
# Role: 'commander' (default) or 'worker'
ORCHESTRATOR_ROLE=commander
# For worker nodes only — URL of the commander
COMMANDER_URL=
# Default tags applied to all fleet-generated wiki pages
ORCHESTRATOR_TAGS=collaborative,ai-generated
# Port this node listens on (workers use this to report their URL)
PORT=3000
